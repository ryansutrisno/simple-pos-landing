---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProblemSection from '../components/ProblemSection.astro';
import FeatureSection from '../components/FeatureSection.astro';
import FitSection from '../components/FitSection.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'POS untuk UMKM | Simpel POS untuk Pantau Toko Lebih Mudah';
const pageDescription =
  'Simpel POS membantu pemilik toko kecil dan UMKM memantau produk, stok, transaksi, keuangan, dan alert reorder dari satu dashboard yang mudah dipahami.';
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />

  <main id="top">
    <Hero />
    <ProblemSection />
    <FeatureSection />
    <FitSection />
    <FAQ />
    <CTA />
  </main>

  <Footer />
</Layout>
