---
const fitReasons = [
  'Fokus ke kebutuhan toko kecil, bukan sistem besar yang terasa terlalu rumit.',
  'Dashboard langsung memberi gambaran kondisi toko dari satu tempat.',
  'Membantu keputusan harian seperti cek stok, pantau transaksi, dan lihat ringkasan produk.',
  'Bahasa dan alurnya dibuat sederhana agar mudah dipahami oleh pemilik UMKM.',
];
---
<section id="cocok-untuk-umkm" class="section-shell fit-section" aria-labelledby="fit-title">
  <div class="fit-copy">
    <p class="eyebrow">Cocok untuk UMKM</p>
    <h2 id="fit-title">Dibuat untuk pemilik toko yang ingin melihat kondisi usaha tanpa ribet.</h2>
    <p>
      Landing page ini fokus pada manfaat praktis: pantau produk, cek stok, lihat transaksi, dan pahami ringkasan toko sebelum meminta preview lebih lanjut.
    </p>
    <ul class="check-list">
      {fitReasons.map((reason) => <li>{reason}</li>)}
    </ul>
  </div>
  <figure class="support-preview">
    <video
      src="/Preview-Dashboard-Simpel-Pos-Preview.mp4"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      aria-label="Video interaktif preview dashboard Simpel POS"
    ></video>
    <figcaption>
      Tampilan dashboard lengkap fitur lebih detail.
    </figcaption>
  </figure>
</section>

<style>
  .fit-copy > p {
    color: var(--muted);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
  }

  .fit-section {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: center;
    min-height: calc(100vh - 6rem);
  }

  .check-list {
    display: grid;
    gap: 0.5rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .check-list li {
    position: relative;
    padding-left: 1.8rem;
    color: var(--muted);
  }

  .check-list li::before {
    position: absolute;
    left: 0;
    top: 0.1rem;
    content: '✓';
    display: grid;
    width: 1.2rem;
    height: 1.2rem;
    place-items: center;
    border-radius: 50%;
    background: var(--brand-soft);
    color: var(--brand-strong);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .support-preview {
    margin: 0;
  }

  .support-preview video {
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    background: var(--surface-strong);
    box-shadow: var(--shadow);
  }

  figcaption {
    margin-top: 0.85rem;
    color: var(--muted);
    font-size: 0.9rem;
    text-align: center;
  }

  @media (max-width: 900px) {
    .fit-section {
      grid-template-columns: 1fr;
    }
  }
</style>
