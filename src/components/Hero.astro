---
import { Image } from 'astro:assets';
import dashboardStatistik from '../assets/Dashboard-Simple-Pos-Statistik.png';
import { whatsappUrl } from '../utils/constants';

const stats = [
  { value: '3', label: 'Total Kategori' },
  { value: '6', label: 'Total Produk' },
  { value: '21', label: 'Total Varian' },
  { value: '11', label: 'Alert Reorder' },
];
---
<section class="hero section-shell" aria-labelledby="hero-title">
  <div class="hero-copy">
    <p class="eyebrow">POS untuk UMKM</p>
    <h1 id="hero-title">Pantau toko lebih mudah dari satu dashboard Simpel POS.</h1>
    <p class="hero-description">
      Simpel POS membantu pemilik toko kecil melihat ringkasan produk, stok,
      transaksi, keuangan, dan alert reorder tanpa harus membuka laporan yang rumit.
    </p>
    <div class="hero-actions" aria-label="Aksi utama">
      <a class="button button-primary" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
        Minta Demo via WhatsApp
      </a>
      <a class="button button-secondary" href="#fitur">Lihat Fitur Dashboard</a>
    </div>
    <dl class="hero-stats" aria-label="Contoh statistik dashboard Simpel POS">
      {stats.map((stat) => (
        <div>
          <dt>{stat.value}</dt>
          <dd>{stat.label}</dd>
        </div>
      ))}
    </dl>
  </div>

  <figure class="hero-preview">
    <Image
      src={dashboardStatistik}
      alt="Preview dashboard statistik Simpel POS untuk memantau kategori, produk, stok, varian, paket aktif, alert reorder, dan grafik transaksi."
      width="1512"
      height="982"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <figcaption>
      Preview dashboard statistik yang membantu pemilik UMKM membaca kondisi toko lebih cepat.
    </figcaption>
  </figure>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 2.5rem;
    align-items: center;
    min-height: calc(100vh - 6rem);
    padding-top: 2.5rem;
  }

  .hero-description {
    max-width: 42rem;
    margin-bottom: 1.25rem;
    color: var(--muted);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
  }

  .hero-stats div {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: rgba(255, 250, 241, 0.72);
    padding: 0.85rem;
  }

  .hero-stats dt {
    font-size: 1.6rem;
    font-weight: 900;
    line-height: 1;
  }

  .hero-stats dd {
    margin: 0.25rem 0 0;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .hero-preview {
    margin: 0;
  }

  .hero-preview img {
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    background: var(--surface-strong);
    box-shadow: var(--shadow);
  }

  figcaption {
    margin-top: 0.85rem;
    color: var(--muted);
    font-size: 0.9rem;
    text-align: center;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 3rem;
      gap: 2rem;
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
